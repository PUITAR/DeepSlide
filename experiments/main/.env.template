## ========================
## 评测环境变量（复制到 .env）
## ========================

## 一、LLM Judge（用于 RSat/SSC/TDQ 等）
## 必填：至少填一套 EVAL_MODEL_*（或用 EVAL_JUDGE_MODEL_* 专门覆盖 judge）。

OPENAI_API_KEY=
LLM_API_KEY=

EVAL_MODEL_PLATFORM_TYPE=OPENAI_COMPATIBLE_MODEL
EVAL_MODEL_TYPE=
EVAL_MODEL_API_URL=
EVAL_MODEL_API_KEY=

EVAL_JUDGE_MODEL_PLATFORM_TYPE=
EVAL_JUDGE_MODEL_TYPE=
EVAL_JUDGE_MODEL_API_URL=
EVAL_JUDGE_MODEL_API_KEY=

## 二、OCR（统一用 API：Qwen3-VL-Flash）
## 必填：DEFAULT_VLM_* 四项 + EVAL_OCR_PROVIDER=aliyun_vlm

EVAL_OCR_PROVIDER=aliyun_vlm
EVAL_OCR_MODE=auto
EVAL_OCR_TIMEOUT_SECONDS=60
EVAL_RENDER_DPI=200
EVAL_OCR_TEXT_MIN_CHARS=40
EVAL_OCR_PROMPT="Please perform OCR recognition: Extract all visible text from the image and output it as plain text in reading order. Do not explain, summarize, or include any extra content."

DEFAULT_VLM_PLATFORM_TYPE=aliyun
DEFAULT_VLM_TYPE=qwen3-vl-flash
DEFAULT_VLM_API_URL=https://dashscope.aliyuncs.com/api/v1
DEFAULT_VLM_API_KEY=

## 三、可选：BERTScore（默认关闭，避免下载模型/占显存）

EVAL_BERTSCORE_ENABLED=0
EVAL_BERTSCORE_MODEL=roberta-base
